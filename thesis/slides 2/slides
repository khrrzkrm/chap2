\section{Use Case 3: Review Mode}

\begin{frame}{Review Mode: The "Auditor"}
    \textbf{Scenario:} Automated Critique via Pull Request.
    \vspace{0.3cm}
    \begin{itemize}
        \item A PR is opened containing the new feature.
        \item The "Copilot Code Review" agent automatically scans the changes.
    \end{itemize}
    \vspace{0.3cm}
    \textbf{Goal:} A final gatekeeper to catch subtle safety violations humans might miss.
\end{frame}

\begin{frame}[fragile]{Review Configuration}
    \textbf{File:} \texttt{.github/copilot-instructions.md}
