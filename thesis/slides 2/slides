\section{Use Case 1: Synchronous Mode}

\begin{frame}{Synchronous Mode: The "Co-pilot"}
    \textbf{Scenario:} Real-time drafting in the IDE (VS Code).
    \vspace{0.3cm}
    \begin{itemize}
        \item The developer is writing the core logic for \texttt{dose\_calc.py}.
        \item The developer types a function signature and waits for completion.
    \end{itemize}
    \vspace{0.3cm}
    \textbf{Goal:} Prevent safety violations \textit{before} the code is even saved.
\end{frame}

\begin{frame}[fragile]{Synchronous Configuration \& Results}
    \textbf{Configuration:} Active \texttt{AGENTS.md} forbids `float`.
    \vspace{0.3cm}
    
    \textbf{Result (Ghost Text):}
    Copilot automatically suggests \texttt{Decimal} and adds traceability tags.
    
    \begin{lstlisting}[language=Python, caption={Real-time Suggestion}]
from decimal import Decimal
from src.utils.tracing import trace

# Copilot auto-generates this based on AGENTS.md rule #2
@trace("REQ-302") 
def calculate_active_insulin(initial: Decimal, time: int) -> Decimal:
    # Copilot uses Decimal() instead of float()
    decay = initial / Decimal(100) 
    return max(Decimal("0.00"), initial - decay * time)
    \end{lstlisting}
\end{frame}

