\section{Use Case 2: Asynchronous Mode}

\begin{frame}{Asynchronous Mode: The "Autopilot"}
    \textbf{Scenario:} Background task execution.
    \vspace{0.3cm}
    \begin{itemize}
        \item The developer assigns a complex verification task to the agent.
        \item \textit{Prompt:} "@copilot generate a test suite for REQ-302 covering edge cases."
    \end{itemize}
    \vspace{0.3cm}
    \textbf{Goal:} Automate tedious verification tasks while maintaining high rigor.
\end{frame}

\begin{frame}[fragile]{Asynchronous Configuration \& Results}
    \textbf{Configuration:} Agent has access to tools: \texttt{pytest}, \texttt{file\_edit}.
    \vspace{0.2cm}
    
    \textbf{Result (Agent Action Log):}
    \begin{enumerate}
        \item \texttt{PLAN:} Read \texttt{reqs.md}. Identify edge cases (negative time, zero dose).
        \item \texttt{EXECUTE:} Create \texttt{tests/test\_dose.py}.
        \item \texttt{VALIDATE:} Run \texttt{pytest}.
        \item \texttt{CORRECT:} Test failed on ZeroDivisionError. Agent modifies code to handle 0 duration.
        \item \texttt{OUTPUT:} Agent opens a Pull Request.
    \end{enumerate}
\end{frame}

